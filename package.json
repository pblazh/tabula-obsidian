{
  "name": "tabula-obsidian",
  "version": "0.2.19",
  "description": "Tabula plugin for Obsidian - CSV transformation with spreadsheet-inspired scripting language",
  "main": "out/main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "jest",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "obsidian",
    "tabula",
    "csv",
    "spreadsheet",
    "data"
  ],
  "author": "Tabula",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/pblazh/tabula-obsidian"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "obsidian": "latest",
    "ts-jest": "^29.4.6",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.0"
  },
  "dependencies": {
    "@fast-csv/parse": "^5.0.5",
    "codemirror": "^6.0.1"
  },
  "lint-staged": {
    "*.{json,md,css,html}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --ext ts,js,jsx,tsx --no-ignore --max-warnings=0"
    ]
  }
}
